# ──────────────────────────────────────────────────────────────────────────
# compliance-agent/.env.example  →  copy to compliance-agent/.env
# .env is git-ignored. The backend reads these to build DATABASE_URL.
# POSTGRES_PASSWORD must match the value in shared/.env.
# ──────────────────────────────────────────────────────────────────────────
# Dedicated DB role for this agent (must match COMPLIANCE_DB_PASSWORD in shared/.env)
COMPLIANCE_DB_PASSWORD=change_me_compliance_password

# Add agent-specific secrets below (API keys, model endpoints, etc.)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

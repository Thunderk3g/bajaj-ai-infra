# ──────────────────────────────────────────────────────────────────────────
# monitoring-agent/.env.example  →  copy to monitoring-agent/.env
# .env is git-ignored. The monitoring backend needs NO database/redis.
# ──────────────────────────────────────────────────────────────────────────

# Docker-compatible REST endpoint the backend reads from. Default points at the
# socket-proxy on the shared network; only override for local experiments.
SOCKET_PROXY_URL=tcp://socket-proxy:2375

# ── Basic-auth (MON_BASIC_AUTH) ─────────────────────────────────────────────
# The /monitoring* section is gated at NGINX, not in this service. There is no
# app-level auth env var to set here; instead you generate an htpasswd file that
# shared-nginx mounts at /etc/nginx/.htpasswd-monitoring:
#
#   htpasswd -c shared/.htpasswd-monitoring monitor
#   # add more users (omit -c so you don't truncate):
#   htpasswd shared/.htpasswd-monitoring alice
#
# Realm string is "Bajaj AI Monitoring" (set in shared/nginx.conf). See README.

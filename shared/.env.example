# ──────────────────────────────────────────────────────────────────────────
# shared/.env.example  →  copy to shared/.env and fill in real values.
# .env is git-ignored. NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────────────────

# Postgres superuser (used by all agents to build their DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=postgres

# Optional: timezone for the shared containers
TZ=Asia/Kolkata

# ──────────────────────────────────────────────────────────────────────────
# shared/.env.example  →  copy to shared/.env and fill in real values.
# .env is git-ignored. NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────────────────

# Postgres superuser (owns the cluster; runs init-db.sh)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=postgres

# Per-agent DB login roles (least privilege). init-db.sh creates one role per
# agent and makes it the owner of that agent's database. Each agent's own .env
# must use the SAME password here for its DATABASE_URL.
COMPLIANCE_DB_PASSWORD=change_me_compliance_password
SEO_DB_PASSWORD=change_me_seo_password
# HR_DB_PASSWORD=change_me_hr_password
# VOICE_DB_PASSWORD=change_me_voice_password

# pgAdmin web login (the UI at http://<host>/pgadmin/). The email is just the
# login id; use a real address format or pgAdmin rejects it at startup.
PGADMIN_DEFAULT_EMAIL=admin@bajajlife.com
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin_password

# Optional: timezone for the shared containers
TZ=Asia/Kolkata
